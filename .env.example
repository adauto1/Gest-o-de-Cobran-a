# 🌐 Configurações de Produção
# Renomeie para .env na VPS e altere os valores

# Segurança (Gere uma chave aleatória)
SESSION_SECRET=substitua-por-uma-chave-longa-e-aleatoria

# Banco de Dados
# Para SQLite dentro do container:
DATABASE_URL=sqlite:///./data/app.db
# O diretório ./data deve ser um volume no docker-compose

# Configurações do App
APP_TITLE=Gestor de Cobrança — Portal Móveis
APP_VERSION=4.0
DATA_DIR=/app/data

# Credenciais Iniciais de Administração
DEFAULT_ADMIN_EMAIL=admin@portalmoveis.local
DEFAULT_ADMIN_PASSWORD=SuaSenhaForteAqui123
